+async def test_send_with_standby_true_skips_bot() -> None:
+    """상담사 주도권 보유(standby=true) 중 send 이벤트는 봇이 응답하지 않는다."""
+    with patch("app.__main__.send_talktalk_message", new_callable=AsyncMock) as mock_send, \
+         patch("app.__main__._process_with_agent", new_callable=AsyncMock) as mock_process, \
+         patch("app.__main__.log_conversation", new_callable=AsyncMock) as mock_log:
+        mock_send.return_value = True
+
+        response = await _call_webhook({
+            "event": "send",
+            "user": "u_standby",
+            "standby": True,
+            "textContent": {"text": "스티커를 전송했습니다.", "inputType": "typing"},
+        })
+
+        mock_send.assert_not_called()
+        mock_process.assert_not_called()
+        mock_log.assert_not_called()
+        assert isinstance(response, JSONResponse)
+        assert response.status_code == 200
+
+
+async def test_counselor_echo_triggers_passthread() -> None:
+    """상담사 echo(sourceId==1+managerNickname) 감지 시 봇이 passThread를 발송한다."""
+    user = "u_counselor"
+    with patch("app.__main__.initiate_counselor_passthread", new_callable=AsyncMock) as mock_passthread:
+        mock_passthread.return_value = True
+
+        response = await _call_webhook({
+            "event": "echo",
+            "user": user,
+            "textContent": {"text": "[상담자개입] 판매중이 아닙니다.", "inputType": "typing"},
+            "options": {"sourceId": 1, "threadOwnerId": 37241, "managerNickname": "이남기"},
+        })
+
+        mock_passthread.assert_called_once_with(user)
+        assert isinstance(response, JSONResponse)
+        assert response.status_code == 200
+
+
+async def test_bot_echo_does_not_trigger_passthread() -> None:
+    """봇이 보낸 메시지 echo(sourceId == partnerId)는 passThread를 발송하지 않는다."""
+    with patch("app.__main__.initiate_counselor_passthread", new_callable=AsyncMock) as mock_passthread:
+        await _call_webhook({
+            "event": "echo",
+            "user": "u_bot_echo",
+            "textContent": {"text": "봇 응답", "inputType": "typing"},
+            "options": {"sourceId": 37241, "threadOwnerId": 37241},
+        })
+        mock_passthread.assert_not_called()
+
+
+async def test_handover_event_skips_bot() -> None:
+    """handover 이벤트는 봇이 응답하지 않는다."""
+    with patch("app.__main__.send_talktalk_message", new_callable=AsyncMock) as mock_send, \
+         patch("app.__main__._process_with_agent", new_callable=AsyncMock) as mock_process:
+        mock_send.return_value = True
+
+        response = await _call_webhook({
+            "event": "handover",
+            "user": "u_handover",
