+async def initiate_counselor_passthread(user_id: str) -> bool:
+    """상담사가 passThread 없이 메시지를 입력한 것을 감지한 경우,
+    봇이 대신 passThread를 발송해 주도권을 공식 이양시킨다.
+
+    이후 사용자 메시지에 네이버가 자동으로 `standby=true`를 부착하므로
+    기존 standby 가드가 봇 응답을 차단한다. 사용자에게 보이는 안내 텍스트는
+    포함하지 않는다(이미 상담사가 응대 중이므로).
+    """
+    if not settings.naver_talk_partner_id:
+        logger.warning("NAVER_TALK_PARTNER_ID 미설정, passThread 건너뜀")
+        return False
+
+    message = NaverTalkTalkModel(
+        event="handover",
+        user=user_id,
+        partner=settings.naver_talk_partner_id,
+        options={
+            "control": "passThread",
+            "targetId": 1,
+        },
+    )
+    headers = {
+        "Content-Type": "application/json",
+        "Authorization": settings.naver_talk_send_token,
+    }
+
+    try:
+        async with httpx.AsyncClient(timeout=30.0) as client:
+            response = await client.post(
+                TALKTALK_API_URL,
+                json=message.model_dump(exclude_none=True),
+                headers=headers,
+            )
+            _ = response.raise_for_status()
+            logger.info("counselor passThread 발송 완료: %s", user_id)
+            return True
+    except Exception as e:
+        logger.error("counselor passThread 발송 실패: %s - %s", user_id, e)
+        return False
