+"""업무시간 SSOT(Single Source of Truth).
+
+평일(월~금) 09:30~17:30 KST. 프롬프트·라우터·서비스는 업무시간을 직접 문자열로
+적지 않고 모두 이 모듈을 참조한다. 영업일·취소 마감일 계산도 여기 정의된
+BUSINESS_END·BUSINESS_WEEKDAYS 를 기준으로 한다.
+"""
+
+import datetime
+
+# datetime.weekday(): 월=0, 화=1, 수=2, 목=3, 금=4, 토=5, 일=6
+BUSINESS_WEEKDAYS: frozenset[int] = frozenset({0, 1, 2, 3, 4})
+
+BUSINESS_START: datetime.time = datetime.time(9, 30)
+BUSINESS_END: datetime.time = datetime.time(17, 30)
+
+
+def format_business_hours() -> str:
+    """프롬프트·응답에 노출할 업무시간 문자열. 예: '평일(월~금) 09:30~17:30 KST'."""
+    return f"평일(월~금) {BUSINESS_START:%H:%M}~{BUSINESS_END:%H:%M} KST"
