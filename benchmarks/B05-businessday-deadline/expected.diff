+def is_business_day(target: date) -> bool:
+    """주어진 날짜가 한국 영업일(평일이며 공휴일이 아님)인지 판정합니다.
+
+    Args:
+        target: 판정할 날짜.
+
+    Returns:
+        평일(월~금)이고 한국 공휴일이 아니면 True.
