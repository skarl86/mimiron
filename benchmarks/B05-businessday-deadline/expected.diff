new file mode 100644
index 0000000..ad502a3
--- /dev/null
+++ b/agents/naver-smartstore/scripts/e2e_cancellation_deadline_webhook.py
@@ -0,0 +1,104 @@
+"""취소 마감일 영업일 보정 — /webhook E2E 검증.
+
+실제 대화(스마트스토어 상품 13369865657, "26일 예약건은 3일전이면 언제까지
+취소해야하나요")를 /webhook 엔드포인트로 재현한다.
+
+- send_talktalk_message / log_conversation 를 패치해 실제 Naver 발송·Supabase
+  기록 없이 봇 응답만 캡처한다 (실제 고객에게 메시지가 가지 않음).
+- compute_cancellation_deadline 를 spy 로 감싸 LLM 이 마감일 도구를 실제로
+  호출했는지, 어떤 날짜를 산출했는지 확인한다.
+- LLM 비결정성(temperature)을 고려해 N회 반복한다.
+
+OPENAI_API_KEY·COMMERCE_API_URL 이 설정된 .env 가 필요하다.
+실행: agents/naver-smartstore 에서 `uv run python scripts/e2e_cancellation_deadline_webhook.py`
+"""
+import sys
+from unittest.mock import patch
+
+from fastapi.testclient import TestClient
+
+import app.__main__ as main_module
+import app.services.cancellation_deadline as cd_module
+
+PRODUCT_NO = "13369865657"
+REFERER = f"https://smartstore.naver.com/tourvisofficial/products/{PRODUCT_NO}"
+MESSAGE = "26일 예약건은 3일전이면 언제까지 취소해야하나요"
+RUNS = 10
+
+_real_compute = cd_module.compute_cancellation_deadline
+
+
+def main() -> int:
+    sent: list[tuple[str, str]] = []
+    tool_calls: list[dict] = []
+
+    async def fake_send(user, text):
+        sent.append((user, text))
+        return {}
+
+    async def fake_log(*args, **kwargs):
+        return None
+
+    def spy_compute(tour_date, days_before):
+        result = _real_compute(tour_date, days_before)
+        tool_calls.append({
+            "tour_date": tour_date.isoformat(),
+            "days_before": days_before,
+            "deadline_date": result["deadline_date"],
+            "adjusted": result["adjusted"],
+        })
+        return result
+
+    failures = 0
+    with patch.object(main_module, "send_talktalk_message", fake_send), \
+         patch.object(main_module, "log_conversation", fake_log), \
+         patch.object(cd_module, "compute_cancellation_deadline", spy_compute):
+        client = TestClient(main_module.app)
+        for i in range(1, RUNS + 1):
+            sent.clear()
+            tool_calls.clear()
+            payload = {
+                "event": "send",
+                "user": f"e2e-cancel-deadline-{i}",  # 실제 사용자 아님
+                "textContent": {"text": MESSAGE},
+                "options": {"referer": REFERER},
+            }
+            resp = client.post("/webhook", json=payload)
+            bot_replies = [t for (_u, t) in sent]
+            final = bot_replies[-1] if bot_replies else "(응답 없음)"
+
+            print(f"\n{'=' * 64}")
+            print(f"Run {i}/{RUNS}  —  HTTP {resp.status_code}")
+            print(f"User: {MESSAGE}")
+            print(f"메시지 발송 횟수: {len(bot_replies)} (interim 포함)")
+            print(f"도구 호출: {tool_calls if tool_calls else '없음'}")
+            print(f"\nBot 최종 응답:\n{final}")
+
+            called = bool(tool_calls)
+            produced_22 = any(c["deadline_date"] == "2026-05-22" for c in tool_calls)
+            mentions_22 = (
+                "2026-05-22" in final
+                or "05-22" in final
+                or "5월 22" in final
+                or "22일" in final
+            )
+
+            if not called:
+                print("\nFAIL: calculate_cancellation_deadline 도구가 호출되지 않음")
+                failures += 1
+            elif not produced_22:
+                print("\nFAIL: 도구는 호출됐으나 마감일이 2026-05-22 가 아님")
+                failures += 1
+            elif not mentions_22:
+                print("\nFAIL: 도구는 05-22 를 산출했으나 응답 본문에 반영되지 않음")
+                failures += 1
+            else:
+                print("\nPASS: 도구 호출 + 영업일 보정(05-22) 산출 + 응답 반영 확인")
+
+    print(f"\n{'=' * 64}")
+    print(f"Summary: {RUNS - failures}/{RUNS} passed")
+    return 1 if failures else 0
+
+
+if __name__ == "__main__":
+    sys.exit(main())
