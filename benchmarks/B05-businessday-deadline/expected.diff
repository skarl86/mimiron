@@ -0,0 +1,57 @@
+import datetime
+
+from app.services.cancellation_deadline import (
+    calculate_cancellation_deadline,
+    compute_cancellation_deadline,
+)
+
+
+def test_compute_deadline_weekend_adjusted():
+    # 이용일 2026-05-26(화), 3일 전 = 05-23(토) → 직전 영업일 05-22(금)
+    result = compute_cancellation_deadline(datetime.date(2026, 5, 26), 3)
+    assert result["calendar_date"] == "2026-05-23"
+    assert result["deadline_date"] == "2026-05-22"
+    assert result["deadline_time"] == "17:30"
+    assert result["adjusted"] is True
+    assert result["weekday_kr"] == "금"
+    assert "2026-05-22" in result["text"]
+
+
+def test_compute_deadline_no_adjustment():
+    # 이용일 2026-05-29(금), 3일 전 = 05-26(화) → 영업일, 보정 없음
+    result = compute_cancellation_deadline(datetime.date(2026, 5, 29), 3)
+    assert result["deadline_date"] == "2026-05-26"
+    assert result["adjusted"] is False
+    assert result["weekday_kr"] == "화"
+
+
+def test_compute_deadline_holiday_adjusted():
+    # 이용일 2026-01-04, 3일 전 = 2026-01-01(신정 공휴일) → 직전 영업일 2025-12-31(수)
+    # 공휴일 보정 + 연말 경계 역행을 함께 검증한다.
+    result = compute_cancellation_deadline(datetime.date(2026, 1, 4), 3)
+    assert result["calendar_date"] == "2026-01-01"
+    assert result["deadline_date"] == "2025-12-31"
+    assert result["adjusted"] is True
+    assert result["weekday_kr"] == "수"
+
+
+def test_tool_weekend_adjusted():
+    result = calculate_cancellation_deadline.invoke(
+        {"tour_date": "2026-05-26", "days_before": 3}
+    )
+    assert result["deadline_date"] == "2026-05-22"
+    assert result["adjusted"] is True
+
+
+def test_tool_rejects_invalid_date():
+    result = calculate_cancellation_deadline.invoke(
+        {"tour_date": "26일", "days_before": 3}
+    )
+    assert "error" in result
+
+
+def test_tool_rejects_negative_days_before():
+    result = calculate_cancellation_deadline.invoke(
+        {"tour_date": "2026-05-26", "days_before": -1}
+    )
+    assert "error" in result
