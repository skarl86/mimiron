diff --git a/agents/naver-smartstore/app/services/cancellation_deadline.py b/agents/naver-smartstore/app/services/cancellation_deadline.py
new file mode 100644
index 0000000..e4cd43f
--- /dev/null
+++ b/agents/naver-smartstore/app/services/cancellation_deadline.py
@@ -0,0 +1,95 @@
+"""취소 접수 마감일 영업일 보정 — 순수 계산 + LLM 도구.
+
+'이용일 N일 전까지 취소' 규정에서 단순 (이용일 - N일)이 주말·공휴일이면
+직전 영업일로 당겨 실제 접수 마감일을 결정한다. 날짜 산술·요일 판정은 코드가
+결정론적으로 담당하고, LLM 은 이용일·기준일수 추출만 맡는다.
+"""
+
+import datetime
+from typing import Any
+
+from langchain_core.tools import tool
+
+from app.business_hours import BUSINESS_END
+from app.logger_config import get_logger
+from app.utils import last_business_day_on_or_before
+
+logger = get_logger(__name__)
+
+_WEEKDAY_KR: tuple[str, ...] = ("월", "화", "수", "목", "금", "토", "일")
+
+
+def compute_cancellation_deadline(tour_date: datetime.date, days_before: int) -> dict[str, Any]:
+    """이용일과 취소 기준일 수로 영업일 보정된 취소 접수 마감일을 계산합니다.
+
+    Args:
+        tour_date: 이용일(투어 날짜).
+        days_before: 취소 가능 기준일 수("이용일 N일 전까지").
+
+    Returns:
+        deadline_date: 영업일 보정된 실제 마감일 (ISO 'YYYY-MM-DD').
+        deadline_time: 마감 시각 'HH:MM' (업무 종료 시각).
+        calendar_date: 보정 전 단순 계산일 (ISO 'YYYY-MM-DD').
+        adjusted: 주말·공휴일 보정이 일어났으면 True.
+        weekday_kr: deadline_date 의 한글 요일.
+        text: 사람이 읽는 한 줄 안내문.
+    """
+    calendar_date = tour_date - datetime.timedelta(days=days_before)
+    deadline_date = last_business_day_on_or_before(calendar_date)
+    adjusted = deadline_date != calendar_date
+    deadline_time = f"{BUSINESS_END:%H:%M}"
+    weekday_kr = _WEEKDAY_KR[deadline_date.weekday()]
+
+    if adjusted:
+        calendar_weekday = _WEEKDAY_KR[calendar_date.weekday()]
+        text = (
+            f"이용일({tour_date.isoformat()}) {days_before}일 전인 "
+            f"{calendar_date.isoformat()}({calendar_weekday})은 영업일이 아니므로, "
+            f"취소 접수 마감은 직전 영업일인 "
+            f"{deadline_date.isoformat()}({weekday_kr}) {deadline_time} KST 입니다."
+        )
+    else:
+        text = (
+            f"이용일({tour_date.isoformat()}) {days_before}일 전인 "
+            f"{deadline_date.isoformat()}({weekday_kr}) {deadline_time} KST 까지 "
+            f"취소 접수가 가능합니다."
+        )
+
+    return {
+        "deadline_date": deadline_date.isoformat(),
+        "deadline_time": deadline_time,
+        "calendar_date": calendar_date.isoformat(),
+        "adjusted": adjusted,
+        "weekday_kr": weekday_kr,
+        "text": text,
+    }
+
+
+@tool(
+    description=(
+        "취소 접수 마감일을 영업일 기준으로 계산합니다. '이용일 N일 전까지 취소 가능' "
+        "규정이 적용되는 상품에서 구체적인 취소 마감 날짜를 안내해야 할 때 호출하세요. "
+        "tour_date 는 'YYYY-MM-DD' 형식의 이용일 문자열, days_before 는 취소 기준일 수(정수)."
+    )
+)
+def calculate_cancellation_deadline(tour_date: str, days_before: int) -> dict[str, Any]:
+    """이용일·취소 기준일 수로 영업일 보정된 취소 마감일을 반환합니다."""
+    try:
+        parsed = datetime.date.fromisoformat(tour_date.strip())
+    except (ValueError, AttributeError):
+        return {
+            "error": "tour_date 는 'YYYY-MM-DD' 형식이어야 합니다.",
+            "tour_date_received": tour_date,
+        }
+    if days_before < 0:
+        return {"error": "days_before 는 0 이상의 정수여야 합니다."}
+
+    result = compute_cancellation_deadline(parsed, days_before)
+    logger.info(
+        "취소 마감일 계산: tour=%s, N=%d → deadline=%s (adjusted=%s)",
+        tour_date,
+        days_before,
+        result["deadline_date"],
+        result["adjusted"],
+    )
+    return result
