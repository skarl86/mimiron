+async def _resolve_product(client: Any, identifier: str) -> dict[str, Any] | None:
+    """PRD 코드 또는 channelProductNo 식별자로 상품 dict 를 조회한다.
+
+    PRD 코드는 search → channelProductNo 추출 후 재조회, channelProductNo 는 직조회.
+    어느 경로든 실패하면 None.
+    """
+    if identifier.startswith("PRD"):
+        search_result = await client.search_products_by_prd(identifier)
+        contents = search_result.get("contents") if search_result else None
+        if isinstance(contents, list) and contents:
+            first = contents[0]
+            channel_no = (
+                str(first.get("channelProductNo", "")) if isinstance(first, dict) else ""
+            )
+            if channel_no:
+                return await client.get_product(channel_no)
+        return None
+    return await client.get_product(identifier)
+
