@@ -13,6 +13,83 @@ from app.utils import build_inline_product_context
 
 logger = get_logger(__name__)
 
+
+class OptionCombinationPrice(TypedDict):
+    option_names: list[str]
+    unit_price: int
+    usable: bool
+
+
+class ResolvedOptionPrices(TypedDict):
+    sale_price: int | None
+    group_labels: list[str]
+    combinations: list[OptionCombinationPrice]
+
+
+def resolve_option_unit_prices(product: dict[str, Any]) -> ResolvedOptionPrices:
+    """옵션 조합별 최종 단가를 단일 진실 소스로 계산한다.
+
+    네이버 Commerce API 의 `salePrice` 와 `optionCombinations[i].price`(차감/추가금)
+    를 합산해 사용자가 결제할 옵션 단가를 산출한다. 다른 가격 캐시(apolloInfo
+    net_price_currency 등) 는 절대 참조하지 않는다.
+
+    Note:
+        옵션 그룹·이름 인덱스는 1~3 만 지원한다 (`range(1, 4)`). 네이버 Commerce API
+        스키마는 `optionGroupName4` / `optionName4` 까지 정의되어 있으나,
+        본 프로젝트에서 4-dimension 옵션 상품을 운영한 사례가 없어 한계를 의도적으로
+        유지한다. 4-dimension 상품 도입 시 두 루프 모두 `range(1, 5)` 로 확장 필요.
+    """
+    empty: ResolvedOptionPrices = {"sale_price": None, "group_labels": [], "combinations": []}
+    detail = product.get("detail")
+    if not isinstance(detail, dict):
+        return empty
+    origin = detail.get("originProduct")
+    if not isinstance(origin, dict):
+        return empty
+
+    sale_price_raw = origin.get("salePrice")
+    sale_price = int(sale_price_raw) if isinstance(sale_price_raw, (int, float)) else None
+
+    option_info = origin.get("optionInfo")
+    if not isinstance(option_info, dict):
+        return {"sale_price": sale_price, "group_labels": [], "combinations": []}
+
+    group_names_data = option_info.get("optionCombinationGroupNames")
+    group_labels: list[str] = []
+    if isinstance(group_names_data, dict):
+        for i in range(1, 4):
+            gname = group_names_data.get(f"optionGroupName{i}")
+            if isinstance(gname, str) and gname:
+                group_labels.append(gname)
+
+    combinations_raw = option_info.get("optionCombinations")
+    combos: list[OptionCombinationPrice] = []
+    if isinstance(combinations_raw, list):
+        for raw in combinations_raw:
+            if not isinstance(raw, dict):
+                continue
+            names: list[str] = []
+            for i in range(1, 4):
+                v = raw.get(f"optionName{i}")
+                if isinstance(v, str) and v:
+                    names.append(v)
+            adjustment_raw = raw.get("price")
+            adjustment = int(adjustment_raw) if isinstance(adjustment_raw, (int, float)) else 0
+            base = sale_price if sale_price is not None else 0
+            usable_flag = raw.get("usable")
+            stock = raw.get("stockQuantity")
+            usable = (usable_flag is not False) and not (isinstance(stock, int) and stock <= 0)
+            combos.append(
+                {
+                    "option_names": names,
+                    "unit_price": base + adjustment,
+                    "usable": usable,
+                }
+            )
+
+    return {"sale_price": sale_price, "group_labels": group_labels, "combinations": combos}
+
+
 _IMG_SRC_PATTERN = re.compile(r'<img[^>]+src=[\"\']([^\"\']+)[\"\']', re.IGNORECASE)
 
 
