new file mode 100644
index 0000000..1e77e40
--- /dev/null
+++ b/agents/naver-smartstore/app/services/price_quote.py
@@ -0,0 +1,129 @@
+"""상품 옵션 견적 결정론 계산.
+
+LLM 산수 환각을 막기 위한 server-side 계산기. 단가는
+`product_context.resolve_option_unit_prices` 의 단일 진실 소스를 사용한다.
+매칭은 모든 keyword 가 옵션 이름 join 안에 포함되어야 하는 AND 매칭.
+"""
+
+from __future__ import annotations
+
+import re
+from dataclasses import dataclass
+from typing import Any
+
+from app.services.product_context import resolve_option_unit_prices
+
+_SLASH_DATE = re.compile(r"\b(\d{1,2})/(\d{1,2})\b")
+
+
+def _normalize(s: str) -> str:
+    """6/6 → 06-06 형태로 약식 날짜 매칭 보강."""
+    s = s.strip().lower()
+    return _SLASH_DATE.sub(lambda m: f"{int(m.group(1)):02d}-{int(m.group(2)):02d}", s)
+
+
+@dataclass(frozen=True)
+class QuoteLineRequest:
+    option_keywords: tuple[str, ...]
+    count: int
+
+    def __post_init__(self) -> None:
+        if not isinstance(self.option_keywords, tuple):
+            object.__setattr__(self, "option_keywords", tuple(self.option_keywords))
+
+
+@dataclass(frozen=True)
+class QuoteResult:
+    ok: bool
+    total: int
+    text: str
+
+
+def _find_combination(
+    combinations: list[dict[str, Any]],
+    keywords: list[str],
+) -> tuple[dict[str, Any] | None, list[dict[str, Any]]]:
+    norm_keywords = [_normalize(k) for k in keywords if k]
+    if not norm_keywords:
+        return None, list(combinations)
+
+    candidates: list[dict[str, Any]] = []
+    for combo in combinations:
+        joined = _normalize(" ".join(combo["option_names"]))
+        if all(k in joined for k in norm_keywords):
+            candidates.append(combo)
+    if len(candidates) == 1:
+        return candidates[0], candidates
+    return None, candidates
+
+
+def compute_quote(product: dict[str, Any], lines: list[QuoteLineRequest]) -> QuoteResult:
+    resolved = resolve_option_unit_prices(product)
+    combinations = resolved["combinations"]
+    if not combinations:
+        return QuoteResult(
+            ok=False,
+            total=0,
+            text="상품에서 옵션 정보를 찾지 못했습니다. 상품 페이지 옵션 표를 확인해 주세요.",
+        )
+    if not lines:
+        return QuoteResult(
+            ok=False,
+            total=0,
+            text="견적 라인이 비어 있습니다. 인원 구분과 수량을 알려주세요.",
+        )
+
+    detail_lines: list[str] = []
+    total = 0
+
+    for idx, req in enumerate(lines, start=1):
+        if req.count <= 0:
+            return QuoteResult(
+                ok=False,
+                total=0,
+                text=f"{idx}번째 옵션 요청: 수량은 1 이상이어야 합니다 (요청: {req.count}).",
+            )
+
+        match, candidates = _find_combination(combinations, list(req.option_keywords))
+        if match is None:
+            kw_text = " ".join(req.option_keywords) or "(빈 키워드)"
+            if not candidates:
+                available = ", ".join(" / ".join(c["option_names"]) for c in combinations[:10])
+                return QuoteResult(
+                    ok=False,
+                    total=0,
+                    text=(
+                        f"{idx}번째 옵션 요청 '{kw_text}' 에 해당하는 옵션을 찾지 못했습니다. "
+                        f"선택 가능한 옵션: {available}"
+                    ),
+                )
+            candidates_text = ", ".join(" / ".join(c["option_names"]) for c in candidates[:10])
+            return QuoteResult(
+                ok=False,
+                total=0,
+                text=(
+                    f"{idx}번째 옵션 요청 '{kw_text}' 키워드에 여러 옵션이 매칭됩니다. "
+                    f"후보: {candidates_text}. 더 구체적으로 알려주세요."
+                ),
+            )
+
+        if not match["usable"]:
+            return QuoteResult(
+                ok=False,
+                total=0,
+                text=f"{idx}번째 옵션 요청 '{' / '.join(match['option_names'])}' 은(는) 현재 선택불가 상태입니다.",
+            )
+
+        line_total = match["unit_price"] * req.count
+        total += line_total
+        detail_lines.append(
+            f"- {' / '.join(match['option_names'])}: "
+            f"{match['unit_price']:,}원 × {req.count} = {line_total:,}원"
+        )
+
+    body = "\n".join(detail_lines)
+    return QuoteResult(
+        ok=True,
+        total=total,
+        text=f"[견적]\n{body}\n총액: {total:,}원",
+    )
