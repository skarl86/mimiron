+"""get_product_info LangChain 도구의 반환값 정합성 회귀 테스트.
+
+2026-05-19 벳푸 사파리 사건 회귀: raw apolloInfo·optionCombinations.price 음수·
+net_price_currency 가 LLM 컨텍스트로 새어 나가지 않도록 잠근다.
+"""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from typing import Any
+from unittest.mock import AsyncMock
+
+import pytest
+
+
+FIXTURE = Path(__file__).parent / "fixtures" / "beppu_safari_13376502159.json"
+
+
+@pytest.fixture
+def beppu_payload() -> dict[str, Any]:
+    return json.loads(FIXTURE.read_text(encoding="utf-8"))
+
+
+@pytest.mark.asyncio
+async def test_get_product_info_returns_curated_text_only(
+    monkeypatch: pytest.MonkeyPatch, beppu_payload: dict[str, Any]
+) -> None:
+    from app.routers import product as product_router
+
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = beppu_payload
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    result = await product_router.get_product_info.ainvoke(
+        {"channel_product_no_or_prd_code": "13376502159"}
+    )
+
+    # 1) 반환 타입은 str (이전: dict)
+    assert isinstance(result, str), f"기대: str, 실제: {type(result).__name__}"
+
+    # 2) 정확한 단가 노출
+    assert "96,530원" in result
+    assert "92,430원" in result
+    assert "30,810원" in result
+
+    # 3) 오염 데이터 누출 차단
+    for forbidden in (
+        "apolloInfo", "net_price_currency",
+        "94,000", "90,000", "30,000", "30,000원",
+        "-4,100", "-4100",
+        "-65,720", "-65720",
+    ):
+        assert forbidden not in result, f"오염 노출: {forbidden}"
+
+    # 4) apollo_client 가 본 라우터에서 import 되지 않음을 모듈 레벨로 검증
+    import app.routers.product as _product_module
+    assert not hasattr(_product_module, "apollo_client"), "apollo_client 가 router 모듈에 남아 있음"
+
+
+@pytest.mark.asyncio
+async def test_get_product_info_returns_empty_message_when_not_found(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    from app.routers import product as product_router
+
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = None
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    result = await product_router.get_product_info.ainvoke(
+        {"channel_product_no_or_prd_code": "99999999999999"}
+    )
+
+    assert isinstance(result, str)
+    assert "찾지 못" in result or "조회되지" in result or "확인할 수 없" in result
+
+
+@pytest.mark.asyncio
+async def test_quote_price_returns_deterministic_total(
+    monkeypatch: pytest.MonkeyPatch, beppu_payload: dict[str, Any]
+) -> None:
+    from app.routers import product as product_router
+
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = beppu_payload
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    result = await product_router.quote_price.ainvoke(
+        {
+            "channel_product_no_or_prd_code": "13376502159",
+            "lines": [
+                {"option_keywords": ["2026-06-06", "성인"], "count": 3},
+                {"option_keywords": ["2026-06-06", "아동"], "count": 1},
+                {"option_keywords": ["2026-06-06", "유아"], "count": 3},
+            ],
+        }
+    )
+
+    assert isinstance(result, str)
+    assert "474,450원" in result
+    assert "289,590원" in result
+    for forbidden in ("428,000", "462,000", "94,000", "90,000", "30,000"):
+        assert forbidden not in result, f"오답 수치 노출: {forbidden}"
+
+
+@pytest.mark.asyncio
+async def test_quote_price_handles_unknown_product(monkeypatch: pytest.MonkeyPatch) -> None:
+    from app.routers import product as product_router
+
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = None
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    result = await product_router.quote_price.ainvoke(
+        {
+            "channel_product_no_or_prd_code": "13376502159",
+            "lines": [{"option_keywords": ["성인"], "count": 1}],
+        }
+    )
+    assert isinstance(result, str)
+    assert "찾지 못" in result or "확인" in result
+
+
+@pytest.mark.asyncio
+async def test_quote_price_rejects_bool_count(
+    monkeypatch: pytest.MonkeyPatch, beppu_payload: dict[str, Any]
+) -> None:
+    """count: True/False 같은 bool 입력은 명시적 에러로 거부 (Python bool ⊂ int 함정)."""
+    from app.routers import product as product_router
+
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = beppu_payload
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    result = await product_router.quote_price.ainvoke(
+        {
+            "channel_product_no_or_prd_code": "13376502159",
+            "lines": [{"option_keywords": ["2026-06-06", "성인"], "count": True}],
+        }
+    )
+    assert isinstance(result, str)
+    assert "형식" in result, f"bool count 가 정상 통과: {result}"
+    # bool count 가 True=1 로 잘못 처리되면 단가가 나올 수 있음 — 절대 금지
+    assert "96,530원" not in result
+    assert "289,590원" not in result
