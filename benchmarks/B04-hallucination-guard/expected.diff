+++ b/agents/naver-smartstore/tests/test_price_quote.py
@@ -0,0 +1,119 @@
+"""compute_quote() 단위 테스트 — 견적은 순수 결정론 계산."""
+
+from __future__ import annotations
+
+import pytest
+
+from app.services.price_quote import QuoteLineRequest, compute_quote
+
+
+@pytest.fixture
+def beppu_product() -> dict:
+    """벳푸 사파리 #13376502159 의 핵심 필드만 추린 미니 fixture."""
+    return {
+        "channelProductNo": "13376502159",
+        "detail": {
+            "originProduct": {
+                "name": "[벳푸 아프리칸 사파리] 후쿠오카 유후인 벳부 일일 소소버스투어",
+                "salePrice": 96530,
+                "optionInfo": {
+                    "optionCombinationGroupNames": {
+                        "optionGroupName1": "출발일",
+                        "optionGroupName2": "인원 구분",
+                    },
+                    "optionCombinations": [
+                        {"optionName1": "2026-06-06", "optionName2": "성인 (만 16세 이상)", "price": 0, "usable": True, "stockQuantity": 10},
+                        {"optionName1": "2026-06-06", "optionName2": "아동 (49개월 이상 ~ 만 16세 미만)", "price": -4100, "usable": True, "stockQuantity": 10},
+                        {"optionName1": "2026-06-06", "optionName2": "소인 (25개월 이상 ~ 48개월 이하)", "price": -4100, "usable": True, "stockQuantity": 10},
+                        {"optionName1": "2026-06-06", "optionName2": "유아 (13개월 이상 ~ 24개월 이하)", "price": -65720, "usable": True, "stockQuantity": 10},
+                    ],
+                },
+            }
+        },
+    }
+
+
+def test_reproduces_incident_total(beppu_product: dict) -> None:
+    """2026-05-19 사건 재현: 6/6 성인3·아동1·유아3 = 474,450원."""
+    lines = [
+        QuoteLineRequest(option_keywords=["2026-06-06", "성인"], count=3),
+        QuoteLineRequest(option_keywords=["2026-06-06", "아동"], count=1),
+        QuoteLineRequest(option_keywords=["2026-06-06", "유아"], count=3),
+    ]
+    result = compute_quote(beppu_product, lines)
+
+    assert result.ok is True
+    assert result.total == 474450
+    assert "289,590원" in result.text
+    assert "92,430원" in result.text
+    assert "30,810원" in result.text
+    assert "474,450원" in result.text
+
+
+def test_partial_keyword_match_resolves_unique_option(beppu_product: dict) -> None:
+    lines = [QuoteLineRequest(option_keywords=["6/6", "성인"], count=2)]
+    result = compute_quote(beppu_product, lines)
+    assert result.ok is True
+    assert result.total == 96530 * 2
+
+
+def test_ambiguous_keyword_returns_error_with_candidates(beppu_product: dict) -> None:
+    """인원 구분 keyword 없이 날짜만 주면 매칭 다수 — 후보 안내."""
+    lines = [QuoteLineRequest(option_keywords=["2026-06-06"], count=1)]
+    result = compute_quote(beppu_product, lines)
+    assert result.ok is False
+    assert "여러" in result.text or "후보" in result.text
+
+
+def test_no_match_returns_error(beppu_product: dict) -> None:
+    lines = [QuoteLineRequest(option_keywords=["2026-12-31", "성인"], count=1)]
+    result = compute_quote(beppu_product, lines)
+    assert result.ok is False
+    assert "선택 가능한 옵션" in result.text
+
+
+def test_unavailable_option_blocks_quote(beppu_product: dict) -> None:
+    import copy
+    product = copy.deepcopy(beppu_product)
+    product["detail"]["originProduct"]["optionInfo"]["optionCombinations"][0]["usable"] = False
+    lines = [QuoteLineRequest(option_keywords=["2026-06-06", "성인 (만"], count=1)]
+    result = compute_quote(product, lines)
+    assert result.ok is False
+    assert "선택불가" in result.text
+
+
+def test_zero_count_is_rejected(beppu_product: dict) -> None:
+    lines = [QuoteLineRequest(option_keywords=["2026-06-06", "성인"], count=0)]
+    result = compute_quote(beppu_product, lines)
+    assert result.ok is False
+
+
+def test_empty_lines_returns_error(beppu_product: dict) -> None:
+    """빈 lines 는 silent ok=True 가 아닌 명시적 에러로 반환."""
+    result = compute_quote(beppu_product, [])
+    assert result.ok is False
+    assert result.total == 0
+    assert "총액: 0원" not in result.text
+    assert "비어" in result.text or "라인" in result.text
+
+
+def test_quote_line_request_is_truly_frozen() -> None:
+    """option_keywords 가 tuple 로 변환되어 mutation 불가능."""
+    req = QuoteLineRequest(option_keywords=["a", "b"], count=1)
+    assert isinstance(req.option_keywords, tuple)
+    assert req.option_keywords == ("a", "b")
+    # frozen=True 가 reference 잠그고 tuple 변환이 내용도 잠금
+    with pytest.raises((AttributeError, Exception)):
+        req.count = 2  # type: ignore[misc]
+
+
+def test_quote_line_request_keyword_listing_in_error_includes_index(beppu_product: dict) -> None:
+    """에러 메시지에 line index 가 포함되어 LLM 이 어느 요청이 실패했는지 안내 가능."""
+    lines = [
+        QuoteLineRequest(option_keywords=["2026-06-06", "성인"], count=1),
+        QuoteLineRequest(option_keywords=["2026-06-06", "외계인"], count=1),  # no-match
+    ]
+    result = compute_quote(beppu_product, lines)
+    assert result.ok is False
+    assert "2번째" in result.text
+    assert "외계인" in result.text
