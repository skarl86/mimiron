+"""2026-05-19 벳푸 사파리 사건 회귀 — LLM 이 quote_price 를 호출했을 때 정확한 총액이
+나오는지, 그리고 get_product_info 가 오염 데이터를 절대 노출하지 않는지 잠근다.
+"""
+
+from __future__ import annotations
+
+import json
+from pathlib import Path
+from unittest.mock import AsyncMock
+
+import pytest
+
+
+FIXTURE = Path(__file__).parent / "fixtures" / "beppu_safari_13376502159.json"
+
+
+@pytest.mark.asyncio
+async def test_quote_price_with_real_fixture_yields_474450(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    from app.routers import product as product_router
+
+    payload = json.loads(FIXTURE.read_text(encoding="utf-8"))
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = payload
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    text = await product_router.quote_price.ainvoke(
+        {
+            "channel_product_no_or_prd_code": "13376502159",
+            "lines": [
+                {"option_keywords": ["6/6", "성인"], "count": 3},
+                {"option_keywords": ["6/6", "아동"], "count": 1},
+                {"option_keywords": ["6/6", "유아"], "count": 3},
+            ],
+        }
+    )
+
+    assert "474,450원" in text
+    assert "289,590원" in text
+    assert "92,430원" in text
+    assert "30,810원" in text
+    for forbidden in ("428,000", "462,000", "94,000", "90,000원", "30,000원"):
+        assert forbidden not in text, f"금지 수치 노출: {forbidden}"
+
+
+@pytest.mark.asyncio
+async def test_get_product_info_text_has_no_pollution(
+    monkeypatch: pytest.MonkeyPatch,
+) -> None:
+    from app.routers import product as product_router
+
+    payload = json.loads(FIXTURE.read_text(encoding="utf-8"))
+    commerce_mock = AsyncMock()
+    commerce_mock.get_product.return_value = payload
+    monkeypatch.setattr(product_router, "_load_commerce_client", lambda: commerce_mock)
+
+    text = await product_router.get_product_info.ainvoke(
+        {"channel_product_no_or_prd_code": "13376502159"}
+    )
+
+    assert "96,530원" in text
+    assert "92,430원" in text
+    assert "30,810원" in text
+
+    for forbidden in (
+        "apolloInfo", "net_price_currency",
+        "94,000", "94000.0",
+        "90,000", "90000.0",
+        "30,000원", "30000.0",
+        "-4,100", "-4100",
+        "-65,720", "-65720",
+    ):
+        assert forbidden not in text, f"오염 노출: {forbidden}"
